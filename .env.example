# Copy this file to .env and fill in the values.
# Never commit real secrets. See README.md → Security.

# Public (client) — safe to expose in the browser bundle
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Server-only mirrors of the above (used by SSR / server functions)
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# Lovable AI Gateway key (auto-provisioned on Lovable Cloud)
LOVABLE_API_KEY=

# Telegram Bot token — required only if you host the bot yourself
TELEGRAM_BOT_TOKEN=
