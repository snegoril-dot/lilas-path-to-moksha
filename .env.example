# Copy this file to .env and fill in the values.
# Never commit real secrets. See README.md → Security.

# Public (client) — safe to expose in the browser bundle
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Server-only mirrors of the above (used by SSR / server functions)
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# Lovable AI Gateway key (auto-provisioned on Lovable Cloud)
LOVABLE_API_KEY=

# ── Telegram bot (webhook) ─────────────────────────────────────
# Token from @BotFather. Server-only, never expose to the browser.
TELEGRAM_BOT_TOKEN=
# HTTPS URL of the deployed Mini App (opens on "Открыть Лилу").
MINI_APP_URL=
# Optional shared secret. If set, must equal the value passed to
# Telegram's setWebhook(secret_token=...).
TELEGRAM_WEBHOOK_SECRET=

